<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB">

    <!-- ── Toolbar ── -->

    <!-- ── Scrollable content ── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="89dp"
        android:background="#1A1A2E"
        app:title="Admin Panel"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── NOW SERVING card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A1A2E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOW SERVING TOKEN"
                        android:textColor="#8B8BAD"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNowServing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="–"
                        android:textColor="@color/white"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/tvServingName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#8B8BAD"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── TOTAL WAITING card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#EEF2FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL WAITING"
                            android:textColor="#6C63FF"
                            android:textSize="11sp"
                            android:letterSpacing="0.12"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotalWaiting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#1A1A2E"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="⏳"
                        android:textSize="24sp"
                        android:gravity="center" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ACTION BUTTONS ── -->
            <!-- Next Token button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextToken"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Next Token"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="#6C63FF"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Complete Current Token button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteToken"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Complete Current Token"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="#10B981"
                app:cornerRadius="12dp"
                android:layout_marginBottom="24dp" />

            <!-- ── QUEUE LIST heading ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="All Tokens"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="#6C63FF"
                    android:visibility="visible" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Queue is empty 🎉"
                android:textSize="14sp"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- RecyclerView is NOT inside a nested ScrollView.
                 We wrap it manually via a fixed height or NestedScrollView in
                 a real project; here we use a NestedScrollView-compatible approach. -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="124dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#EF4444"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
